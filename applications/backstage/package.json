{
  "name": "root",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20 || 22"
  },
  "scripts": {
    "start": "dotenv -e ../../.env -- backstage-cli repo start",
    "start:dev": "dotenv -e ../../.env -- backstage-cli repo start --config app-config.yaml",
    "start:local": "./start.sh",
    "build:backend": "dotenv -e ../../.env -- yarn workspace backend build",
    "build:all": "dotenv -e ../../.env -- backstage-cli repo build --all",
    "build-image": "yarn workspace backend build-image",
    "build": "dotenv -e ../../.env -- backstage-cli package build",
    "tsc": "tsc",
    "tsc:full": "tsc --skipLibCheck false --incremental false",
    "clean": "backstage-cli repo clean",
    "test": "dotenv -e ../../.env -- backstage-cli repo test",
    "test:all": "dotenv -e ../../.env -- backstage-cli repo test --coverage",
    "test:e2e": "playwright test",
    "fix": "backstage-cli repo fix",
    "lint": "backstage-cli repo lint --since origin/master",
    "lint:all": "backstage-cli repo lint",
    "prettier:check": "prettier --check .",
    "new": "backstage-cli new"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "plugins/*"
    ]
  },
  "devDependencies": {
    "@backstage/cli": "^0.33.1",
    "@backstage/e2e-test-utils": "^0.1.1",
    "@playwright/test": "^1.32.3",
    "dotenv-cli": "^10.0.0",
    "node-gyp": "^10.0.0",
    "prettier": "^2.3.2",
    "typescript": "~5.8.0"
  },
  "resolutions": {
    "@types/react": "^18",
    "@types/react-dom": "^18"
  },
  "prettier": "@backstage/cli/config/prettier",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@4.4.1",
  "dependencies": {
    "@backstage/plugin-azure-devops": "^0.4.4",
    "@backstage/plugin-cost-insights": "^0.12.24",
    "@backstage/plugin-github-actions": "^0.6.16",
    "@backstage/plugin-tech-radar": "^0.7.4",
    "@backstage/plugin-techdocs": "^1.13.2"
  }
}
