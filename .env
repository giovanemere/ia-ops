AUTH_GITHUB_CLIENT_SECRET=09f84b4714065574f4e2b42d74d9e67a69df2172

# TechDocs Configuration
TECHDOCS_BUILDER=local
TECHDOCS_GENERATOR_RUNIN=docker
TECHDOCS_PUBLISHER_TYPE=local
TECHDOCS_PORT=8006
TECHDOCS_DOCKER_IMAGE=spotify/techdocs
TECHDOCS_PUBLISH_DIR=./techdocs

# GitHub Actions Plugin
GITHUB_ACTIONS_PROXY_PATH=/github-actions
GITHUB_ACTIONS_REFRESH_INTERVAL=600000

# =============================================================================
# 📚 CONFIGURACIÓN DE DOCUMENTACIÓN
# =============================================================================
