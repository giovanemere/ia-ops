# =============================================================================
# 🔧 CONFIGURACIÓN GENERAL
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=info

# =============================================================================
# 📦 REPOSITORIOS EXTERNOS
# =============================================================================
