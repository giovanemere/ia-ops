GRAFANA_PORT=3001
GRAFANA_LOG_LEVEL=info
GRAFANA_DB_USER=grafana_user
GRAFANA_DB_PASSWORD=grafana_pass_2025
GRAFANA_DB_NAME=grafana_db

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_TIME=15d

# Node Exporter
