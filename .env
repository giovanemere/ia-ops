# =============================================================================
# 🔍 CONFIGURACIÓN DE MÉTRICAS
# =============================================================================
ENABLE_METRICS=true
ACCESS_LOG=true

# =============================================================================
# 📝 NOTAS IMPORTANTES
# =============================================================================
# 
# 🔐 SEGURIDAD:
# - Cambia todas las contraseñas en producción
# - Usa secretos seguros para BACKEND_SECRET y API_SECRET_KEY
# - Configura GITHUB_TOKEN para integración con GitHub
# - Configura OPENAI_API_KEY para funcionalidad de IA
#
# 🗄️ BASES DE DATOS:
# - backstage_db: Solo para Backstage (catálogo, auth, techdocs)
# - grafana_db: Solo para Grafana (dashboards, usuarios, alertas)
# - monitoring_db: Para analytics de OpenAI y métricas generales
#
# 🚀 PUERTOS:
# - 8080: Proxy principal (punto de entrada)
# - 3002: Backstage Frontend
# - 7007: Backstage Backend
# - 8003: OpenAI Service
# - 8005: MkDocs
# - 8006: TechDocs
# - 3001: Grafana
# - 9090: Prometheus
# - 5432: PostgreSQL
# - 6379: Redis
#
# =============================================================================

