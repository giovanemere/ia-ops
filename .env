# =============================================================================
# 🤖 OPENAI SERVICE
# =============================================================================

# OpenAI Service Configuration
OPENAI_SERVICE_HOST=openai-service
OPENAI_SERVICE_PORT=8000
OPENAI_SERVICE_URL=http://openai-service:8000

# OpenAI Service Features
OPENAI_DEMO_MODE=true
OPENAI_RATE_LIMIT=100
OPENAI_TIMEOUT=30

# OpenAI Integration with Backstage
OPENAI_BACKSTAGE_PROXY_PATH=/openai
OPENAI_BACKSTAGE_ENABLED=true
OPENAI_KNOWLEDGE_BASE_ENABLED=true
OPENAI_KNOWLEDGE_BASE_PATH=./knowledge/applications.yaml
OPENAI_KNOWLEDGE_BASE_UPDATE_INTERVAL=300

# OpenAI Advanced Features
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
OPENAI_EMBEDDINGS_ENABLED=false
OPENAI_FUNCTION_CALLING_ENABLED=false
OPENAI_STREAMING_ENABLED=false

# OpenAI Health Check
OPENAI_HEALTH_CHECK_ENABLED=true
OPENAI_HEALTH_CHECK_ENDPOINT=/health
OPENAI_HEALTH_CHECK_INTERVAL=30

