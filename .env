# =============================================================================
# CONFIGURACIÓN DE PUERTOS - MAPA COMPLETO DE LA SOLUCIÓN
# =============================================================================

# 🌐 PROXY SERVICE (Gateway Principal)
PROXY_PORT=8080
PROXY_HOST=0.0.0.0

# 🏛️ BACKSTAGE SERVICES
BACKSTAGE_BACKEND_PORT=7007
BACKSTAGE_FRONTEND_PORT=3002

# 🤖 OPENAI SERVICE
OPENAI_SERVICE_PORT=8003
OPENAI_METRICS_PORT=8004

# 📚 DOCUMENTATION SERVICES
MKDOCS_PORT=8005
TECHDOCS_PORT=8006

# 💾 DATABASE SERVICES
POSTGRES_PORT=5432
REDIS_PORT=6379

# 📊 MONITORING SERVICES
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
NODE_EXPORTER_PORT=9100
CADVISOR_PORT=8082

# 🔧 ADDITIONAL SERVICES
NGINX_PROXY_PORT=8081

# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=backstage
POSTGRES_HOST=postgres

# =============================================================================
# CONFIGURACIÓN DE REDIS
# =============================================================================
REDIS_PASSWORD=redis123
REDIS_HOST=redis
REDIS_DB=0

# =============================================================================
# CONFIGURACIÓN DE BACKSTAGE
# =============================================================================
NODE_ENV=development
BACKEND_SECRET=Z72c/FuIlpZvf8M1lM8xyvS8h4Q6hl1TNJGujYbQeOM=

# GitHub Integration
GITHUB_TOKEN=dummy-token-not-used
AUTH_GITHUB_CLIENT_ID=dummy-client-id-not-used
AUTH_GITHUB_CLIENT_SECRET=dummy-client-secret-not-used
GITHUB_ORG=tu-organizacion

# Base URLs
BACKSTAGE_BASE_URL=http://localhost:8080
BACKSTAGE_FRONTEND_URL=http://localhost:3002

# =============================================================================
# CONFIGURACIÓN DE OPENAI SERVICE
# =============================================================================
OPENAI_API_KEY=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
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_SERVICE_URL=http://openai-service:8000

# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_RELOAD=false
FASTAPI_DEBUG=false

# =============================================================================
# CONFIGURACIÓN DE MONITOREO
# =============================================================================

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123
GRAFANA_LOG_LEVEL=info

# Prometheus
PROMETHEUS_RETENTION_TIME=15d

# =============================================================================
# CONFIGURACIÓN DE SEGURIDAD
# =============================================================================

# API Security
API_SECRET_KEY=your-secret-key-here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:8080
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:8080

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# CONFIGURACIÓN DE LOGGING Y DEBUGGING
# =============================================================================
LOG_LEVEL=info
ACCESS_LOG=true
ENABLE_METRICS=true

# =============================================================================
# CONFIGURACIÓN DE DOCUMENTACIÓN
# =============================================================================

# MkDocs
MKDOCS_DEV_ADDR=0.0.0.0:8000
MKDOCS_STRICT=false
MKDOCS_VERBOSE=true

# TechDocs
TECHDOCS_BUILDER=local
TECHDOCS_GENERATOR_RUNIN=local
TECHDOCS_PUBLISHER_TYPE=local
TECHDOCS_STORAGE_PATH=/tmp/techdocs

# =============================================================================
# CONFIGURACIÓN DE CATÁLOGO
# =============================================================================
CATALOG_LOCATIONS=

# =============================================================================
# CONFIGURACIÓN DE DESARROLLO
# =============================================================================

# Environment
ENVIRONMENT=development
DEBUG_MODE=true

# Docker Configuration
COMPOSE_PROJECT_NAME=ia-ops
COMPOSE_FILE=docker-compose.yml

