FRAMEWORK_REPO=https://github.com/giovanemere/ia-ops-framework.git
TEMPLATES_BRANCH=trunk
FRAMEWORK_BRANCH=trunk

# =============================================================================
# 💾 CONFIGURACIÓN DE BASE DE DATOS PRINCIPAL (PostgreSQL)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSL=false

# Variables para Backstage (base de datos separada)
POSTGRES_USER=backstage_user
POSTGRES_PASSWORD=backstage_pass_2025
POSTGRES_DB=backstage_db

# Puertos de Backstage
BACKSTAGE_BACKEND_PORT=7007
BACKSTAGE_FRONTEND_PORT=3002
BACKSTAGE_BASE_URL=http://localhost:8080

# Configuración de autenticación
BACKEND_SECRET=UhxmuObYBkbddlb2KKMsK+oCx67gV3otp499tdsqRJlFiF57ZihPKFHA4otoT3usJHpGecQEotIh5sxCc+z41g==

# UI/UX Configuration
ENABLE_DARK_MODE_ENHANCEMENTS=true
THEME_MODE=auto

# GitHub Integration - Personal Access Token para integración con repositorios
GITHUB_TOKEN=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

# GitHub Organization para auto-discovery
GITHUB_ORG=giovanemere

# GitHub OAuth - Para autenticación de usuarios (opcional)
