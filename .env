# =============================================================================
# IA-OPS PLATFORM - ENVIRONMENT VARIABLES
# =============================================================================
# Fecha: 8 de Agosto de 2025
# Descripción: Variables de entorno con bases de datos separadas
# =============================================================================

# =============================================================================
# 🔧 CONFIGURACIÓN GENERAL
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=info

# =============================================================================
# 💾 CONFIGURACIÓN DE BASE DE DATOS PRINCIPAL (PostgreSQL)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_SSL=false

# =============================================================================
# 🏛️ CONFIGURACIÓN DE BACKSTAGE
# =============================================================================
# Base de datos separada para Backstage
BACKSTAGE_DB_USER=backstage_user
BACKSTAGE_DB_PASSWORD=backstage_pass_2025
BACKSTAGE_DB_NAME=backstage_db

# Puertos de Backstage
BACKSTAGE_BACKEND_PORT=7007
BACKSTAGE_FRONTEND_PORT=3002
BACKSTAGE_BASE_URL=http://localhost:8080

# Configuración de autenticación
BACKEND_SECRET=your-backstage-secret-key-2025
GITHUB_TOKEN=
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=
GITHUB_ORG=tu-organizacion

# TechDocs
TECHDOCS_BUILDER=local
TECHDOCS_GENERATOR_RUNIN=local
TECHDOCS_PUBLISHER_TYPE=local
TECHDOCS_PORT=8006

# =============================================================================
# 📚 CONFIGURACIÓN DE DOCUMENTACIÓN
# =============================================================================
# MkDocs (no usa base de datos)
MKDOCS_PORT=8005
MKDOCS_DEV_ADDR=0.0.0.0:8000
MKDOCS_STRICT=false
MKDOCS_VERBOSE=true

# =============================================================================
# 📊 CONFIGURACIÓN DE MONITOREO
# =============================================================================
# Grafana con base de datos separada
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123
GRAFANA_PORT=3001
GRAFANA_LOG_LEVEL=info
GRAFANA_DB_USER=grafana_user
GRAFANA_DB_PASSWORD=grafana_pass_2025
GRAFANA_DB_NAME=grafana_db

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_TIME=15d

# Node Exporter
NODE_EXPORTER_PORT=9100

# cAdvisor
CADVISOR_PORT=8082

# =============================================================================
# 🤖 CONFIGURACIÓN DE INTELIGENCIA ARTIFICIAL
# =============================================================================
# OpenAI Service con base de datos separada para analytics
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_SERVICE_PORT=8003
OPENAI_METRICS_PORT=8004

# Base de datos para analytics de IA
MONITORING_DB_USER=monitoring_user
MONITORING_DB_PASSWORD=monitoring_pass_2025
MONITORING_DB_NAME=monitoring_db

# FastAPI
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_RELOAD=false
FASTAPI_DEBUG=false

# =============================================================================
# 🌐 CONFIGURACIÓN DE PROXY Y GATEWAY
# =============================================================================
PROXY_PORT=8080
PROXY_HOST=0.0.0.0
NGINX_PROXY_PORT=8081

# CORS y seguridad
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
API_SECRET_KEY=your-api-secret-key-2025

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# 🔄 CONFIGURACIÓN DE REDIS
# =============================================================================
REDIS_PASSWORD=redis123
REDIS_PORT=6379
REDIS_DB=0

# Redis databases por servicio
REDIS_DB_BACKSTAGE=0
REDIS_DB_OPENAI=1
REDIS_DB_CACHE=2

# =============================================================================
# 🔍 CONFIGURACIÓN DE MÉTRICAS
# =============================================================================
ENABLE_METRICS=true
ACCESS_LOG=true

# =============================================================================
# 📝 NOTAS IMPORTANTES
# =============================================================================
# 
# 🔐 SEGURIDAD:
# - Cambia todas las contraseñas en producción
# - Usa secretos seguros para BACKEND_SECRET y API_SECRET_KEY
# - Configura GITHUB_TOKEN para integración con GitHub
# - Configura OPENAI_API_KEY para funcionalidad de IA
#
# 🗄️ BASES DE DATOS:
# - backstage_db: Solo para Backstage (catálogo, auth, techdocs)
# - grafana_db: Solo para Grafana (dashboards, usuarios, alertas)
# - monitoring_db: Para analytics de OpenAI y métricas generales
#
# 🚀 PUERTOS:
# - 8080: Proxy principal (punto de entrada)
# - 3002: Backstage Frontend
# - 7007: Backstage Backend
# - 8003: OpenAI Service
# - 8005: MkDocs
# - 8006: TechDocs
# - 3001: Grafana
# - 9090: Prometheus
# - 5432: PostgreSQL
# - 6379: Redis
#
# =============================================================================
