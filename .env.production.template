# =============================================================================
# IA-OPS PLATFORM - PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Fecha: 8 de Agosto de 2025
# Versión: 2.0.0
# Descripción: Variables de entorno para producción Backstage
# =============================================================================

# =============================================================================
# 🔐 SECURITY & AUTHENTICATION
# =============================================================================
BACKEND_SECRET=your-super-secret-backend-key-change-this-in-production
AUTH_GITHUB_CLIENT_ID=your-github-oauth-client-id
AUTH_GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_TOKEN=your-github-personal-access-token

# =============================================================================
# 🗄️ DATABASE CONFIGURATION
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=backstage
POSTGRES_SSL=false

# =============================================================================
# 🔄 CACHE CONFIGURATION
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# =============================================================================
# 🌐 SERVICE URLS
# =============================================================================
BACKSTAGE_BASE_URL=http://localhost:8080
BACKSTAGE_FRONTEND_URL=http://localhost:3002
BACKSTAGE_BACKEND_PORT=7007
BACKSTAGE_FRONTEND_PORT=3002

# =============================================================================
# 🤖 OPENAI INTEGRATION
# =============================================================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_SERVICE_URL=http://openai-service:8000

# =============================================================================
# ☸️ KUBERNETES INTEGRATION
# =============================================================================
K8S_CLUSTER_URL=https://your-kubernetes-cluster
K8S_SERVICE_ACCOUNT_TOKEN=your-service-account-token

# =============================================================================
# 📊 MONITORING
# =============================================================================
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
ENABLE_METRICS=true

# =============================================================================
# 🔧 APPLICATION SETTINGS
# =============================================================================
NODE_ENV=production
LOG_LEVEL=info
ENABLE_CORS=true
ENABLE_HTTPS=false

# =============================================================================
# 📚 TECHDOCS
# =============================================================================
TECHDOCS_BUILDER=local
TECHDOCS_GENERATOR=docker
TECHDOCS_PUBLISHER=local

# =============================================================================
# 🏗️ BUILD SETTINGS
# =============================================================================
NODE_OPTIONS=--max-old-space-size=4096
YARN_CACHE_FOLDER=/tmp/.yarn-cache
