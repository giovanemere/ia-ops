# =============================================================================
# IA-OPS PLATFORM - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copia este archivo a .env y completa con tus valores reales
# NUNCA subas el archivo .env al repositorio
# =============================================================================

# =============================================================================
# 🔧 CONFIGURACIÓN GENERAL
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=info

# =============================================================================
# 📦 REPOSITORIOS EXTERNOS
# =============================================================================
TEMPLATES_REPO=https://github.com/tu-usuario/templates_backstage.git
FRAMEWORK_REPO=https://github.com/tu-usuario/ia-ops-framework.git
TEMPLATES_BRANCH=trunk
FRAMEWORK_BRANCH=trunk

# =============================================================================
# 💾 CONFIGURACIÓN DE BASE DE DATOS PRINCIPAL (PostgreSQL)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSL=false

# Variables para Backstage (base de datos separada)
POSTGRES_USER=backstage_user
POSTGRES_PASSWORD=tu_password_seguro_aqui
POSTGRES_DB=backstage_db

# Puertos de Backstage
BACKSTAGE_BACKEND_PORT=7007
BACKSTAGE_FRONTEND_PORT=3002
BACKSTAGE_BASE_URL=http://localhost:8080

# Configuración de autenticación
BACKEND_SECRET=genera_un_secret_seguro_de_64_caracteres_aqui

# UI/UX Configuration
ENABLE_DARK_MODE_ENHANCEMENTS=true
THEME_MODE=auto

# =============================================================================
# 🐙 GITHUB INTEGRATION
# =============================================================================
# Personal Access Token para integración con repositorios
GITHUB_TOKEN=ghp_tu_token_personal_aqui

# GitHub Organization para auto-discovery
GITHUB_ORG=tu-organizacion

# GitHub OAuth App (crear en GitHub Settings > Developer settings > OAuth Apps)
AUTH_GITHUB_CLIENT_ID=tu_client_id_aqui
AUTH_GITHUB_CLIENT_SECRET=tu_client_secret_aqui
AUTH_GITHUB_CALLBACK_URL=http://localhost:3002/api/auth/github/handler/frame

# =============================================================================
# 🤖 OPENAI CONFIGURATION
# =============================================================================
# API Key de OpenAI (obtener en https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-tu_api_key_de_openai_aqui

# Configuración del modelo
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=150
OPENAI_TEMPERATURE=0.7

# =============================================================================
# 🔄 PROXY SERVICE CONFIGURATION
# =============================================================================
PROXY_SERVICE_HOST=0.0.0.0
PROXY_SERVICE_PORT=8080
PROXY_TIMEOUT=30000

# URLs de servicios
PROXY_BACKSTAGE_FRONTEND_URL=http://localhost:3002
PROXY_BACKSTAGE_BACKEND_URL=http://localhost:7007
PROXY_OPENAI_SERVICE_URL=http://localhost:8003

# Configuración de CORS
PROXY_CORS_ENABLED=true
PROXY_RATE_LIMIT=1000

# Logging
PROXY_LOGGING_ENABLED=true

# =============================================================================
# 📊 MONITORING CONFIGURATION
# =============================================================================
# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_TIME=15d

# Grafana
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# =============================================================================
# 🐳 DOCKER CONFIGURATION
# =============================================================================
# Redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_aqui

# Network
DOCKER_NETWORK_NAME=ia-ops-network

# =============================================================================
# 🔐 SECURITY CONFIGURATION
# =============================================================================
# JWT Secret para autenticación
JWT_SECRET=otro_secret_seguro_para_jwt_aqui

# Session Secret
SESSION_SECRET=session_secret_seguro_aqui

# =============================================================================
# 📝 INSTRUCCIONES DE USO
# =============================================================================
#
# 1. Copia este archivo: cp .env.example .env
# 2. Completa todos los valores marcados con "tu_*_aqui"
# 3. Genera secrets seguros para BACKEND_SECRET, JWT_SECRET, etc.
# 4. Obtén tokens de GitHub y OpenAI desde sus respectivas plataformas
# 5. Configura OAuth App en GitHub para AUTH_GITHUB_CLIENT_ID/SECRET
# 6. Nunca subas el archivo .env al repositorio
#
# Para generar secrets seguros, puedes usar:
# openssl rand -base64 64
#
# =============================================================================
